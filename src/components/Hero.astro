---
import data from '../data/cursos.json';
import instituciones from '../data/instituciones.json';
const total = data.cursos.length;
const numInstituciones = instituciones.length;
const numDisciplinas = new Set(data.cursos.map((c) => c.disciplina)).size;
---

<header class="hero">
  <div class="contenedor hero__inner">
    <span class="hero__badge">Guía Nacional · Julio – Agosto 2026</span>
    <h1 class="hero__titulo">
      Transforma tu Práctica Clínica: Guía de Educación Continua en Rehabilitación en Colombia
    </h1>
    <p class="hero__subtitulo">
      Descubre las mejores opciones de cursos, diplomados y especializaciones en
      <strong>Fisioterapia</strong>, <strong>Fonoaudiología</strong> y
      <strong>Terapia Ocupacional</strong> para potenciar tu perfil profesional ante los
      nuevos retos del sistema de salud colombiano.
    </p>
    <div class="hero__acciones">
      <a class="btn" href="#oferta">Explorar Oferta Académica</a>
      <a class="btn btn--secundario" href="#categorias">Ver por disciplina</a>
    </div>
    <ul class="hero__stats">
      <li><strong>{total}+</strong> programas vigentes</li>
      <li><strong>{numInstituciones}</strong> instituciones aliadas</li>
      <li><strong>{numDisciplinas}</strong> disciplinas de rehabilitación</li>
    </ul>
  </div>
</header>

<style>
  .hero {
    color: #fff;
    padding: 5rem 0 3.5rem;
    position: relative;
  }
  .hero__inner { position: relative; z-index: 1; max-width: 900px; }
  .hero__badge {
    display: inline-block;
    background: var(--glass-bg-fuerte);
    -webkit-backdrop-filter: blur(var(--blur));
    backdrop-filter: blur(var(--blur));
    border: 1px solid var(--glass-borde-fuerte);
    padding: 0.45rem 1.1rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--texto);
    margin-bottom: 1.4rem;
  }
  .hero__titulo {
    color: #fff;
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin-bottom: 1.1rem;
    letter-spacing: -0.02em;
  }
  .hero__subtitulo {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    color: var(--texto-suave);
    max-width: 720px;
    margin-bottom: 2rem;
  }
  .hero__subtitulo strong {
    color: transparent;
    background: linear-gradient(90deg, var(--azul), var(--verde));
    -webkit-background-clip: text;
    background-clip: text;
    font-weight: 700;
  }
  .hero__acciones { display: flex; gap: 1rem; flex-wrap: wrap; }
  .hero__stats {
    list-style: none;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 0;
    margin: 2.5rem 0 0;
  }
  .hero__stats li {
    font-size: 0.9rem;
    color: var(--texto-suave);
    background: var(--glass-bg);
    -webkit-backdrop-filter: blur(var(--blur));
    backdrop-filter: blur(var(--blur));
    border: 1px solid var(--glass-borde);
    border-radius: 14px;
    padding: 0.9rem 1.3rem;
  }
  .hero__stats strong { display: block; font-size: 1.8rem; color: #fff; }
</style>
