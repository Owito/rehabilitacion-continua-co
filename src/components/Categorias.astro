---
const categorias = [
  {
    nombre: 'Fisioterapia',
    color: '#0f4c81',
    icono: '🦴',
    descripcion: 'Formación en áreas críticas de alta demanda clínica:',
    tendencias: [
      'Suelo pélvico (fisioterapia pelviperineal)',
      'Cuidado crítico en UCI',
      'Neuromodulación y dolor orofacial',
      'Rehabilitación cardiopulmonar',
    ],
  },
  {
    nombre: 'Fonoaudiología',
    color: '#16a085',
    icono: '🗣️',
    descripcion: 'Programas para hiperespecializar tu intervención comunicativa:',
    tendencias: [
      'Trastornos de los sonidos del habla (TSH)',
      'Evaluación instrumental de la deglución (disfagia)',
      'Vocología',
      'Audiología',
    ],
  },
  {
    nombre: 'Terapia Ocupacional',
    color: '#b9770e',
    icono: '🧩',
    descripcion: 'Enfoques que amplían tu campo de acción profesional:',
    tendencias: [
      'Salud mental y arteterapia',
      'Cuidados paliativos',
      'Conciencia corporal basal (BBAT)',
      'Seguridad y salud en el trabajo (SST)',
    ],
  },
];
---

<section class="seccion seccion--gris" id="categorias">
  <div class="contenedor">
    <span class="seccion__eyebrow">Por disciplina</span>
    <h2 class="seccion__titulo">Categorías académicas y tendencias de formación</h2>
    <p class="seccion__intro">
      Navega según tu disciplina y descubre las líneas de formación que hoy marcan la diferencia
      en el mercado laboral de la salud en Colombia.
    </p>

    <div class="cat__grid">
      {categorias.map((c) => (
        <article class="cat__card" style={`--acento:${c.color}`}>
          <div class="cat__head">
            <span class="cat__icono" aria-hidden="true">{c.icono}</span>
            <h3>{c.nombre}</h3>
          </div>
          <p class="cat__desc">{c.descripcion}</p>
          <ul class="cat__lista">
            {c.tendencias.map((t) => <li>{t}</li>)}
          </ul>
          <a class="cat__link" href={`#oferta`} data-disciplina={c.nombre}>
            Ver programas de {c.nombre} →
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cat__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .cat__card {
    background: var(--blanco);
    border-radius: var(--radio);
    border-top: 5px solid var(--acento);
    padding: 1.8rem;
    box-shadow: var(--sombra);
    display: flex;
    flex-direction: column;
  }
  .cat__head { display: flex; align-items: center; gap: 0.7rem; margin-bottom: 0.6rem; }
  .cat__icono { font-size: 1.9rem; }
  .cat__head h3 { color: var(--acento); margin: 0; font-size: 1.4rem; }
  .cat__desc { color: var(--texto-suave); margin: 0 0 1rem; }
  .cat__lista { list-style: none; padding: 0; margin: 0 0 1.4rem; flex: 1; }
  .cat__lista li {
    padding: 0.5rem 0 0.5rem 1.6rem;
    border-bottom: 1px dashed var(--gris-borde);
    position: relative;
  }
  .cat__lista li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--acento);
    font-weight: 700;
  }
  .cat__link { color: var(--acento); font-weight: 600; text-decoration: none; }
  .cat__link:hover { text-decoration: underline; }
</style>
