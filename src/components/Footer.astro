---
// BOLETÍN — Web3Forms (gratis, sin crear cuenta, 250 envíos/mes).
// Para activarlo: entra a https://web3forms.com, escribe tu correo y te llega una
// "Access Key". Pégala abajo (o defínela como variable de entorno PUBLIC_WEB3FORMS_KEY).
const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY || 'd32984b5-21cf-43b7-8cd3-00574f2f170c';
const newsletterActivo = WEB3FORMS_KEY !== 'PEGA_TU_ACCESS_KEY_AQUI' && WEB3FORMS_KEY.length > 10;
---

<footer class="footer" id="contacto">
  <div class="contenedor footer__grid">
    <div class="footer__col footer__brand">
      <h3>Educación Continua en Rehabilitación · Colombia</h3>
      <p>
        Directorio independiente de oferta académica en Fisioterapia, Fonoaudiología y Terapia
        Ocupacional. Actualizado automáticamente cada semana.
      </p>
    </div>

    <div class="footer__col">
      <h4>Recursos</h4>
      <ul>
        <li><a href="#oferta">Rutas de homologación</a></li>
        <li><a href="#contacto">Contacto</a></li>
        <li><a href="https://www.icetex.gov.co/" target="_blank" rel="noopener noreferrer">Financiación / ICETEX</a></li>
        <li><a href="#privacidad">Políticas de privacidad</a></li>
      </ul>
    </div>

    <div class="footer__col footer__news">
      <h4>Boletín mensual</h4>
      <p>Recibe las nuevas oportunidades de formación en tu correo.</p>
      <form id="newsletter-form" class="footer__form" data-activo={String(newsletterActivo)}>
        <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
        <input type="hidden" name="subject" value="Nueva suscripción — Boletín Rehabilitación CO" />
        <input type="hidden" name="from_name" value="Directorio Rehabilitación CO" />
        <input type="checkbox" name="botcheck" class="footer__hp" tabindex="-1" autocomplete="off" />
        <input type="email" name="email" placeholder="tu@correo.com" required aria-label="Correo electrónico" />
        <button type="submit" class="btn">Suscribirme</button>
        <small id="newsletter-msg" class="footer__nota" role="status" aria-live="polite">
          {!newsletterActivo && 'Pendiente: configura tu Access Key de Web3Forms para activar el boletín.'}
        </small>
      </form>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="contenedor">
      <p id="privacidad">
        © 2026 Guía de Educación Continua en Rehabilitación. La información se recopila de portales
        oficiales y puede cambiar; verifica siempre con cada institución. No almacenamos datos
        personales sin consentimiento.
      </p>
    </div>
  </div>
</footer>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const msg = document.getElementById('newsletter-msg');
  if (form && msg && form.dataset.activo === 'true') {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.textContent = 'Enviando…';
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
          body: new FormData(form),
        });
        const data = await res.json();
        if (data.success) {
          form.reset();
          msg.textContent = '¡Listo! Te suscribiste al boletín. ✅';
        } else {
          msg.textContent = 'No se pudo suscribir. Intenta de nuevo más tarde.';
        }
      } catch {
        msg.textContent = 'Error de red. Revisa tu conexión e intenta otra vez.';
      }
    });
  }
</script>

<style>
  .footer {
    background: rgba(255, 255, 255, 0.03);
    -webkit-backdrop-filter: blur(var(--blur));
    backdrop-filter: blur(var(--blur));
    border-top: 1px solid var(--glass-borde);
    color: var(--texto-suave);
    padding: 3.5rem 0 0;
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.5fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }
  .footer h3 { color: #fff; font-size: 1.15rem; }
  .footer h4 { color: #fff; font-size: 1rem; margin-bottom: 0.9rem; }
  .footer p { font-size: 0.92rem; }
  .footer__col ul { list-style: none; padding: 0; margin: 0; }
  .footer__col li { margin-bottom: 0.5rem; }
  .footer__col a { color: var(--texto-suave); text-decoration: none; font-size: 0.92rem; }
  .footer__col a:hover { color: var(--verde); }
  .footer__form { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 0.8rem; }
  .footer__form input[type="email"] {
    flex: 1;
    min-width: 180px;
    padding: 0.8rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--glass-borde);
    background: rgba(255, 255, 255, 0.06);
    color: var(--texto);
    font-family: inherit;
    font-size: 0.95rem;
  }
  .footer__form input[type="email"]::placeholder { color: var(--texto-suave); }
  .footer__form .btn { padding: 0.8rem 1.5rem; font-size: 0.95rem; }
  /* honeypot anti-spam: oculto para humanos */
  .footer__hp { position: absolute; left: -9999px; opacity: 0; height: 0; width: 0; }
  .footer__nota { width: 100%; color: rgba(255, 255, 255, 0.7); font-size: 0.8rem; }
  .footer__bottom { border-top: 1px solid rgba(255, 255, 255, 0.15); padding: 1.4rem 0; }
  .footer__bottom p { font-size: 0.82rem; color: rgba(255, 255, 255, 0.6); margin: 0; }

  @media (max-width: 760px) {
    .footer__grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
