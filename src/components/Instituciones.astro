---
import instituciones from '../data/instituciones.json';
const ordenadas = [...instituciones].sort((a, b) => a.nombre.localeCompare(b.nombre, 'es'));
---

<section class="seccion" id="instituciones">
  <div class="contenedor">
    <span class="seccion__eyebrow">Aliados académicos</span>
    <h2 class="seccion__titulo">Instituciones destacadas</h2>
    <p class="seccion__intro">
      Estas son las entidades que lideran la oferta de educación continua en rehabilitación en
      Colombia. Haz clic para visitar su portal oficial de programas.
    </p>

    <div class="inst__grid">
      {ordenadas.map((i) => (
        <a class="inst__card" href={i.url} target="_blank" rel="noopener noreferrer">
          <span class="inst__nombre">{i.nombre}</span>
          <span class="inst__ciudad">📍 {i.ciudad}</span>
          <span class="inst__disc">{i.disciplinas.join(' · ')}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .inst__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 2.5rem;
  }
  .inst__card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    background: var(--blanco);
    border: 1px solid var(--gris-borde);
    border-radius: var(--radio);
    padding: 1.2rem;
    text-decoration: none;
    color: var(--texto);
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .inst__card:hover {
    transform: translateY(-3px);
    box-shadow: var(--sombra);
    border-color: var(--azul-claro);
  }
  .inst__nombre { font-weight: 700; color: var(--azul-oscuro); line-height: 1.3; }
  .inst__ciudad { font-size: 0.85rem; color: var(--texto-suave); }
  .inst__disc { font-size: 0.78rem; color: var(--verde); font-weight: 600; }
</style>
