---
const modalidades = [
  {
    nombre: 'Virtual',
    etiqueta: 'Asincrónica / Sincrónica',
    icono: '💻',
    texto: 'Ideal para el manejo del tiempo. Accede a la mejor educación desde cualquier región del país sin desplazarte.',
  },
  {
    nombre: 'Híbrida / Semipresencial',
    etiqueta: 'Teoría + práctica intensiva',
    icono: '🔄',
    texto: 'Teoría online combinada con bloques de simulación práctica intensiva presencial para consolidar destrezas.',
  },
  {
    nombre: 'Presencial',
    etiqueta: 'Nodos urbanos principales',
    icono: '🏛️',
    texto: 'Concentrada en Bogotá, Medellín, Cali, Bucaramanga y Cúcuta para el desarrollo de destrezas manuales.',
  },
];
---

<section class="seccion" id="modalidades">
  <div class="contenedor">
    <span class="seccion__eyebrow">Cómo estudiar</span>
    <h2 class="seccion__titulo">Modalidades de estudio</h2>
    <p class="seccion__intro">
      La digitalización permite a los profesionales colombianos acceder a formación de alto nivel
      desde cualquier región. Elige la modalidad que mejor se adapte a tu ritmo y a tus objetivos
      clínicos.
    </p>

    <div class="mod__grid">
      {modalidades.map((m) => (
        <article class="mod__card">
          <span class="mod__icono" aria-hidden="true">{m.icono}</span>
          <h3>{m.nombre}</h3>
          <span class="mod__etiqueta">{m.etiqueta}</span>
          <p>{m.texto}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .mod__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .mod__card {
    background: var(--verde-suave);
    border-radius: var(--radio);
    padding: 1.8rem;
    border: 1px solid #cdeae3;
  }
  .mod__icono { font-size: 2rem; }
  .mod__card h3 { margin: 0.6rem 0 0.2rem; font-size: 1.25rem; }
  .mod__etiqueta {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--verde);
    margin-bottom: 0.7rem;
  }
  .mod__card p { color: var(--texto-suave); margin: 0; }
</style>
