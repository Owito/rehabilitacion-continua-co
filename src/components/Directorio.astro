---
import data from '../data/cursos.json';
import { ordenarMeses, rangoMeses } from '../utils/meses.js';
const { cursos, actualizado, fuente } = data;

const disciplinas = [...new Set(cursos.map((c) => c.disciplina))].sort();
const modalidades = [...new Set(cursos.map((c) => c.modalidad))].sort();
const meses = ordenarMeses(cursos.map((c) => c.mes));
const rango = rangoMeses(cursos.map((c) => c.mes));

const colorDisciplina = {
  'Fisioterapia': '#2f6df0',
  'Fonoaudiología': '#19b58a',
  'Terapia Ocupacional': '#ff7a3c',
};

const fechaFmt = new Date(actualizado + 'T00:00:00').toLocaleDateString('es-CO', {
  day: 'numeric', month: 'long', year: 'numeric',
});
---

<section class="seccion" id="oferta">
  <div class="contenedor">
    <span class="seccion__eyebrow">Oferta vigente</span>
    <h1 class="seccion__titulo">Directorio de programas{rango ? ` — ${rango}` : ''}</h1>
    <p class="seccion__intro">
      Filtra por disciplina, modalidad y mes para encontrar el programa ideal. Cada tarjeta enlaza
      a la fuente oficial de la institución.
    </p>

    <p class="dir__aviso">
      <span aria-hidden="true">🔄</span> Oferta actualizada {fuente === 'automatico' ? 'automáticamente' : '(datos iniciales)'} el
      <strong>{fechaFmt}</strong>. Verifica siempre <strong>fechas, costos y cupos</strong> en el
      enlace oficial de cada institución.
    </p>

    <div class="dir__buscador">
      <label for="dir-busqueda" class="dir__grupo-label">Buscar</label>
      <input
        type="search"
        id="dir-busqueda"
        class="dir__input"
        placeholder="Buscar por programa o institución…"
        aria-label="Buscar por programa o institución"
        autocomplete="off"
      />
    </div>

    <div class="dir__filtros" role="group" aria-label="Filtros de programas">
      <div class="dir__grupo">
        <span class="dir__grupo-label">Disciplina</span>
        <button class="chip activo" data-tipo="disciplina" data-valor="todas" aria-pressed="true">Todas</button>
        {disciplinas.map((d) => (
          <button class="chip" data-tipo="disciplina" data-valor={d} aria-pressed="false">{d}</button>
        ))}
      </div>
      <div class="dir__grupo">
        <span class="dir__grupo-label">Modalidad</span>
        <button class="chip activo" data-tipo="modalidad" data-valor="todas" aria-pressed="true">Todas</button>
        {modalidades.map((m) => (
          <button class="chip" data-tipo="modalidad" data-valor={m} aria-pressed="false">{m}</button>
        ))}
      </div>
      <div class="dir__grupo">
        <span class="dir__grupo-label">Mes</span>
        <button class="chip activo" data-tipo="mes" data-valor="todas" aria-pressed="true">Todos</button>
        {meses.map((m) => (
          <button class="chip" data-tipo="mes" data-valor={m} aria-pressed="false">{m}</button>
        ))}
      </div>
      <button id="dir-limpiar" class="dir__limpiar" type="button"><span aria-hidden="true">✕</span> Limpiar filtros</button>
    </div>

    <p class="dir__contador" id="dir-contador"></p>

    <div class="dir__grid" id="dir-grid">
      {cursos.map((c) => (
        <article
          class="curso"
          data-disciplina={c.disciplina}
          data-modalidad={c.modalidad}
          data-mes={c.mes}
          data-buscar={`${c.titulo} ${c.institucion} ${c.tema}`.toLowerCase()}
          style={`--acento:${colorDisciplina[c.disciplina] ?? 'var(--azul)'}`}
        >
          <div class="curso__top">
            <span class="curso__tag curso__tag--tipo">{c.tipo}</span>
            <span class="curso__tag curso__tag--mod">{c.modalidad}</span>
          </div>
          <h3 class="curso__titulo">{c.titulo}</h3>
          <p class="curso__institucion">{c.institucion}</p>
          <ul class="curso__meta">
            <li class="curso__disciplina">{c.disciplina}</li>
            <li><span aria-hidden="true">📍</span> {c.ciudad}</li>
            <li><span aria-hidden="true">🗓️</span> {c.mes}</li>
          </ul>
          <a
            class="curso__cta"
            href={c.enlace}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${c.titulo} — abre el sitio oficial en una pestaña nueva`}
          >
            Ver en sitio oficial <span aria-hidden="true">↗</span>
          </a>
        </article>
      ))}
    </div>
    <p class="dir__vacio" id="dir-vacio" hidden>No hay programas que coincidan con los filtros seleccionados.</p>
  </div>
</section>

<script>
  const filtros = { disciplina: 'todas', modalidad: 'todas', mes: 'todas' };
  let busqueda = '';
  const grid = document.getElementById('dir-grid');
  const contador = document.getElementById('dir-contador');
  const vacio = document.getElementById('dir-vacio');
  const input = document.getElementById('dir-busqueda') as HTMLInputElement | null;
  const cursos = Array.from(grid?.querySelectorAll('.curso') ?? []);

  function aplicar() {
    let visibles = 0;
    cursos.forEach((card) => {
      const el = card as HTMLElement;
      const ok =
        (filtros.disciplina === 'todas' || el.dataset.disciplina === filtros.disciplina) &&
        (filtros.modalidad === 'todas' || el.dataset.modalidad === filtros.modalidad) &&
        (filtros.mes === 'todas' || el.dataset.mes === filtros.mes) &&
        (busqueda === '' || (el.dataset.buscar ?? '').includes(busqueda));
      el.hidden = !ok;
      if (ok) visibles++;
    });
    if (contador) contador.textContent = `${visibles} programa${visibles === 1 ? '' : 's'} encontrado${visibles === 1 ? '' : 's'}`;
    if (vacio) vacio.hidden = visibles !== 0;
  }

  // Marca un chip como activo dentro de su grupo (y refleja aria-pressed).
  function activar(btn: HTMLElement) {
    const tipo = btn.dataset.tipo!;
    document.querySelectorAll(`.chip[data-tipo="${tipo}"]`).forEach((b) => {
      const on = b === btn;
      b.classList.toggle('activo', on);
      b.setAttribute('aria-pressed', String(on));
    });
  }

  document.querySelectorAll('.chip').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      filtros[el.dataset.tipo as keyof typeof filtros] = el.dataset.valor!;
      activar(el);
      aplicar();
    });
  });

  // Buscador por título / institución / tema
  input?.addEventListener('input', () => {
    busqueda = input.value.trim().toLowerCase();
    aplicar();
  });

  // Botón "Limpiar filtros": vuelve los 3 grupos a "todas" y borra la búsqueda
  document.getElementById('dir-limpiar')?.addEventListener('click', () => {
    filtros.disciplina = 'todas';
    filtros.modalidad = 'todas';
    filtros.mes = 'todas';
    busqueda = '';
    if (input) input.value = '';
    document.querySelectorAll('.chip').forEach((b) => {
      const on = (b as HTMLElement).dataset.valor === 'todas';
      b.classList.toggle('activo', on);
      b.setAttribute('aria-pressed', String(on));
    });
    aplicar();
  });

  aplicar();
</script>

<style>
  .dir__aviso {
    background: var(--blanco);
    border: var(--borde-grueso);
    box-shadow: var(--sombra-dura-sm);
    padding: 0.85rem 1.1rem;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--tinta);
    margin: 1.6rem 0 2rem;
  }
  .dir__aviso strong { font-weight: 800; }
  .dir__buscador { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.3rem; }
  .dir__input {
    width: 100%;
    max-width: 480px;
    padding: 0.8rem 1.1rem;
    border: var(--borde-grueso);
    border-radius: 0;
    background: var(--blanco);
    box-shadow: var(--sombra-dura-sm);
    color: var(--tinta);
    font-family: inherit;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .dir__input::placeholder { color: var(--texto-suave); font-weight: 600; }
  .dir__filtros {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.6rem;
    margin-bottom: 1.2rem;
    align-items: center;
  }
  .dir__grupo { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; }
  .dir__grupo-label {
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--tinta);
    margin-right: 0.3rem;
  }
  .chip {
    background: var(--blanco);
    border: var(--borde-grueso);
    border-radius: 0;
    padding: 0.42rem 0.95rem;
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
    cursor: pointer;
    color: var(--tinta);
    font-family: inherit;
    box-shadow: var(--sombra-dura-sm);
    transition: transform 0.1s ease, box-shadow 0.1s ease, background 0.1s ease;
  }
  .chip:hover { transform: translate(-1px, -1px); box-shadow: 5px 5px 0 var(--tinta); }
  .chip.activo { background: var(--tinta); color: var(--papel); }
  .dir__limpiar {
    align-self: center;
    background: transparent;
    border: none;
    color: var(--tinta);
    font-family: inherit;
    font-weight: 800;
    font-size: 0.82rem;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    padding: 0.4rem 0.3rem;
  }
  .dir__contador { color: var(--texto-suave); font-weight: 700; font-size: 0.9rem; margin: 0 0 1.5rem; }

  .dir__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .curso {
    background: var(--blanco);
    border: var(--borde-grueso);
    border-radius: 0;
    padding: 1.4rem;
    display: flex;
    flex-direction: column;
    box-shadow: var(--sombra-dura);
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }
  .curso:hover {
    transform: translate(-3px, -3px);
    box-shadow: 11px 11px 0 var(--acento);
  }
  .curso__top { display: flex; gap: 0.5rem; margin-bottom: 0.7rem; flex-wrap: wrap; }
  .curso__tag {
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 0.22rem 0.55rem;
    border: 2px solid var(--tinta);
  }
  .curso__tag--tipo { background: var(--acento); color: var(--tinta); }
  .curso__tag--mod { background: var(--blanco); color: var(--tinta); }
  .curso__titulo { font-size: 1.25rem; font-weight: 900; line-height: 1.05; margin: 0 0 0.3rem; color: var(--tinta); }
  .curso__institucion { color: var(--tinta); font-weight: 700; margin: 0 0 0.9rem; font-size: 0.92rem; }
  .curso__meta {
    list-style: none;
    padding: 0;
    margin: 0 0 1.1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.9rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--texto-suave);
    flex: 1;
  }
  .curso__disciplina { color: var(--tinta); font-weight: 800; }
  .curso__cta {
    align-self: flex-start;
    margin-top: auto;
    color: var(--papel);
    background: var(--tinta);
    font-weight: 900;
    text-transform: uppercase;
    font-size: 0.8rem;
    text-decoration: none;
    padding: 0.55rem 1rem;
  }
  .curso__cta:hover { background: var(--acento); color: var(--tinta); }
  .dir__vacio { text-align: center; color: var(--tinta); font-weight: 700; padding: 2rem; }
</style>
