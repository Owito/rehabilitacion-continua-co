---
export interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
const url = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
---

<!doctype html>
<html lang="es-CO">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:locale" content="es_CO" />

    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🧠</text></svg>" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    /* Acentos (brillantes para fondo oscuro) */
    --azul: #4d9fff;
    --azul-claro: #76b6ff;
    --verde: #2dd4bf;
    --amarillo: #f5c14e;
    /* Disciplinas */
    --disc-fisio: #4d9fff;
    --disc-fono: #2dd4bf;
    --disc-to: #f5b563;
    /* Texto */
    --texto: #e7ecf3;
    --texto-suave: #9fb0c3;
    --blanco: #ffffff;
    /* Vidrio (glassmorphism) */
    --glass-bg: rgba(255, 255, 255, 0.055);
    --glass-bg-fuerte: rgba(255, 255, 255, 0.09);
    --glass-borde: rgba(255, 255, 255, 0.12);
    --glass-borde-fuerte: rgba(255, 255, 255, 0.22);
    --blur: 16px;
    --radio: 18px;
    --sombra: 0 10px 30px rgba(0, 0, 0, 0.35);
    --sombra-fuerte: 0 18px 50px rgba(0, 0, 0, 0.5);
    --ancho: 1140px;
    --fuente: "Segoe UI", system-ui, -apple-system, Roboto, Helvetica, Arial, sans-serif;
  }

  * { box-sizing: border-box; }

  /* El atributo [hidden] es display:none del navegador (baja prioridad) y lo pisa
     cualquier regla de display del autor (p. ej. .curso{display:flex}). Esto lo fuerza,
     para que el filtrado del directorio realmente oculte las tarjetas. */
  [hidden] { display: none !important; }

  html { scroll-behavior: smooth; }

  /* Accesibilidad: foco visible claro para teclado */
  :focus-visible { outline: 2px solid var(--azul); outline-offset: 2px; border-radius: 4px; }

  /* Respeta a quienes prefieren menos movimiento */
  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* La nav fija mide 62px; evita que tape el encabezado al saltar por anclas (#oferta…). */
  :where(section, header, footer)[id],
  [id] { scroll-margin-top: 80px; }

  body {
    margin: 0;
    font-family: var(--fuente);
    color: var(--texto);
    background-color: #070b14;
    /* Luces ambientales: dan algo que desenfocar al vidrio */
    background-image:
      radial-gradient(60rem 60rem at 12% -10%, rgba(77, 159, 255, 0.22), transparent 60%),
      radial-gradient(50rem 50rem at 95% 5%, rgba(45, 212, 191, 0.18), transparent 60%),
      radial-gradient(55rem 55rem at 50% 110%, rgba(124, 92, 255, 0.16), transparent 60%);
    background-attachment: fixed;
    background-repeat: no-repeat;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }

  h1, h2, h3, h4 { line-height: 1.2; color: #f3f7fc; margin: 0 0 0.5em; }

  a { color: var(--azul); }

  /* Utilidad glassmorphism */
  .glass {
    background: var(--glass-bg);
    -webkit-backdrop-filter: blur(var(--blur));
    backdrop-filter: blur(var(--blur));
    border: 1px solid var(--glass-borde);
    border-radius: var(--radio);
    box-shadow: var(--sombra);
  }

  .contenedor {
    width: 100%;
    max-width: var(--ancho);
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .seccion { padding: 4rem 0; }

  .seccion__eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--verde);
    margin-bottom: 0.6rem;
  }

  .seccion__titulo { font-size: clamp(1.7rem, 3.5vw, 2.3rem); }
  .seccion__intro { max-width: 760px; color: var(--texto-suave); font-size: 1.08rem; }

  .btn {
    display: inline-block;
    background: linear-gradient(135deg, var(--azul), #7c5cff);
    color: #fff;
    font-weight: 700;
    text-decoration: none;
    padding: 0.9rem 2rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    cursor: pointer;
    font-size: 1.05rem;
    box-shadow: 0 8px 24px rgba(77, 159, 255, 0.35);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .btn:hover { transform: translateY(-2px); box-shadow: 0 14px 36px rgba(124, 92, 255, 0.45); }

  .btn--secundario {
    background: var(--glass-bg-fuerte);
    color: #fff;
    -webkit-backdrop-filter: blur(var(--blur));
    backdrop-filter: blur(var(--blur));
    border: 1px solid var(--glass-borde-fuerte);
    box-shadow: none;
  }
  .btn--secundario:hover { background: rgba(255,255,255,0.14); box-shadow: none; }

  @media (max-width: 640px) {
    .seccion { padding: 2.5rem 0; }
  }
</style>
