---
export interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
const url = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
---

<!doctype html>
<html lang="es-CO">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:locale" content="es_CO" />

    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🧠</text></svg>" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    /* Neo-brutalismo: papel + tinta */
    --tinta: #16140f;       /* casi negro */
    --papel: #fbe9c8;       /* fondo crema */
    --blanco: #ffffff;
    /* Acentos planos por disciplina */
    --fisio: #2f6df0;
    --fono: #19b58a;
    --to: #ff7a3c;
    --lila: #b69bff;
    --disc-fisio: #2f6df0;
    --disc-fono: #19b58a;
    --disc-to: #ff7a3c;
    /* compat con componentes existentes */
    --azul: #2f6df0;
    --verde: #19b58a;
    --texto: #16140f;
    --texto-suave: #5a5346;
    --ancho: 1140px;
    --borde-grueso: 3px solid var(--tinta);
    --sombra-dura: 8px 8px 0 var(--tinta);
    --sombra-dura-sm: 4px 4px 0 var(--tinta);
    --fuente: "Segoe UI", system-ui, -apple-system, Roboto, Helvetica, Arial, sans-serif;
  }

  * { box-sizing: border-box; }

  /* El atributo [hidden] es display:none del navegador (baja prioridad) y lo pisa
     cualquier regla de display del autor (p. ej. .curso{display:flex}). Esto lo fuerza,
     para que el filtrado del directorio realmente oculte las tarjetas. */
  [hidden] { display: none !important; }

  html { scroll-behavior: smooth; }

  /* Accesibilidad: foco visible claro para teclado */
  :focus-visible { outline: 3px solid var(--fisio); outline-offset: 2px; }

  /* Respeta a quienes prefieren menos movimiento */
  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* La nav fija mide ~62px; evita que tape el encabezado al saltar por anclas. */
  :where(section, header, footer)[id],
  [id] { scroll-margin-top: 84px; }

  body {
    margin: 0;
    font-family: var(--fuente);
    color: var(--texto);
    background-color: var(--papel);
    /* textura sutil de puntos sobre el papel */
    background-image: radial-gradient(rgba(22,20,15,0.06) 1.3px, transparent 1.3px);
    background-size: 22px 22px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }

  h1, h2, h3, h4 { line-height: 1.05; color: var(--tinta); margin: 0 0 0.5em; }

  a { color: var(--fisio); }

  .contenedor {
    width: 100%;
    max-width: var(--ancho);
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .seccion { padding: 3rem 0 4rem; }

  .seccion__eyebrow {
    display: inline-block;
    background: var(--tinta);
    color: var(--papel);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 4px;
    margin-bottom: 0.8rem;
  }

  .seccion__titulo {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .seccion__intro { max-width: 760px; color: var(--tinta); font-weight: 600; font-size: 1.05rem; }

  .btn {
    display: inline-block;
    background: var(--tinta);
    color: var(--papel);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    text-decoration: none;
    padding: 0.85rem 1.6rem;
    border: var(--borde-grueso);
    border-radius: 0;
    cursor: pointer;
    font-size: 0.95rem;
    box-shadow: var(--sombra-dura-sm);
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }
  .btn:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--tinta); }
  .btn:active { transform: translate(0, 0); box-shadow: 2px 2px 0 var(--tinta); }

  @media (max-width: 640px) {
    .seccion { padding: 2rem 0 3rem; }
  }
</style>
