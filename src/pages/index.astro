---
import Layout from '../layouts/Layout.astro';
import Directorio from '../components/Directorio.astro';
import data from '../data/cursos.json';
import { rangoMeses } from '../utils/meses.js';

const rango = rangoMeses(data.cursos.map((c) => c.mes));
const periodo = rango ? ` (${rango})` : '';
const title = `Educación Continua en Rehabilitación en Colombia | Fisioterapia, Fonoaudiología y Terapia Ocupacional${periodo}`;
const description = `Directorio de cursos, diplomados y especializaciones en Rehabilitación Humana en Colombia. Oferta vigente de Fisioterapia, Fonoaudiología y Terapia Ocupacional${rango ? ` para ${rango}` : ''}.`;
---

<Layout title={title} description={description}>
  <nav class="nav">
    <div class="contenedor nav__inner">
      <a class="nav__logo" href="#"><span aria-hidden="true">🧠</span> Rehabilitación<span class="nav__logo-co">·CO</span></a>
    </div>
  </nav>

  <main>
    <Directorio />
  </main>

  <button id="ir-arriba" class="ir-arriba" type="button" aria-label="Volver arriba" hidden>
    <span aria-hidden="true">↑</span>
  </button>
</Layout>

<script>
  const btn = document.getElementById('ir-arriba');
  if (btn) {
    const alternar = () => { btn.hidden = window.scrollY < 600; };
    window.addEventListener('scroll', alternar, { passive: true });
    alternar();
    btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  }
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 14, 24, 0.55);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--glass-borde);
  }
  .nav__inner { display: flex; align-items: center; justify-content: space-between; height: 62px; }
  .nav__logo { font-weight: 800; color: #f3f7fc; text-decoration: none; font-size: 1.15rem; }
  .nav__logo-co { color: var(--verde); }

  .ir-arriba {
    position: fixed;
    right: 1.4rem;
    bottom: 1.4rem;
    z-index: 60;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    font-size: 1.3rem;
    line-height: 1;
    color: #fff;
    cursor: pointer;
    background: rgba(255, 255, 255, 0.08);
    -webkit-backdrop-filter: blur(var(--blur));
    backdrop-filter: blur(var(--blur));
    border: 1px solid var(--glass-borde-fuerte);
    box-shadow: var(--sombra);
    transition: transform 0.15s ease, background 0.15s ease;
  }
  .ir-arriba:hover { transform: translateY(-2px); background: rgba(255, 255, 255, 0.16); }
</style>
