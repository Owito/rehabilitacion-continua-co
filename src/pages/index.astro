---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Directorio from '../components/Directorio.astro';
import Instituciones from '../components/Instituciones.astro';
import Footer from '../components/Footer.astro';

const title = 'Educación Continua en Rehabilitación en Colombia | Fisioterapia, Fonoaudiología y Terapia Ocupacional (Julio – Agosto)';
const description = 'Directorio de cursos, diplomados y especializaciones en Rehabilitación Humana en Colombia. Encuentra oferta vigente de Fisioterapia, Fonoaudiología y Terapia Ocupacional para julio y agosto.';
---

<Layout title={title} description={description}>
  <nav class="nav">
    <div class="contenedor nav__inner">
      <a class="nav__logo" href="#">🧠 Rehabilitación<span>·CO</span></a>
      <div class="nav__links">
        <a href="#oferta">Oferta vigente</a>
        <a href="#instituciones">Aliados académicos</a>
      </div>
    </div>
  </nav>

  <Hero />
  <Directorio />
  <Instituciones />
  <Footer />
</Layout>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 14, 24, 0.55);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--glass-borde);
  }
  .nav__inner { display: flex; align-items: center; justify-content: space-between; height: 62px; }
  .nav__logo { font-weight: 800; color: #f3f7fc; text-decoration: none; font-size: 1.15rem; }
  .nav__logo span { color: var(--verde); }
  .nav__links { display: flex; gap: 1.4rem; }
  .nav__links a {
    color: var(--texto-suave);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
  }
  .nav__links a:hover { color: #fff; }
  @media (max-width: 560px) {
    .nav__links { gap: 1rem; font-size: 0.85rem; }
    .nav__links a { font-size: 0.85rem; }
  }
</style>
